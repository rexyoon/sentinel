# 이 파일을 .env 로 복사한 뒤 값을 채우세요. (.env 는 절대 커밋하지 않는다)
#   cp .env.example .env

# --- PostgreSQL ---
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=change-me
POSTGRES_DB=sentinel
# 호스트에 노출할 포트. 5432/6379를 이미 다른 서비스가 쓰고 있다면 바꿔서 피한다.
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PORT=6379

# --- server-kotlin ---
# Ktor 서버가 리슨할 포트 (8080이 이미 사용 중이면 변경)
SERVER_PORT=8080
