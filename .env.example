# 이 파일을 .env 로 복사한 뒤 실제 키를 채우세요. (.env 는 커밋 금지)
#   cp .env.example .env

# 전부 지금은 비워둬도 됩니다 — 골격 먼저, 실제 구동할 때 채웁니다.

# 기획자(Claude). https://console.anthropic.com
ANTHROPIC_API_KEY=

# 디자이너(OpenAI). https://platform.openai.com
OPENAI_API_KEY=

# 나머지 직원들(Kimi / Moonshot, OpenAI 호환). https://platform.moonshot.ai
MOONSHOT_API_KEY=
